# Environment variables for the decision pipeline

# Debug mode (set to False in production)
# DEBUG=True

# API Configuration (fill in API url and endpoints)
# API_KEY=
# API_BASE_URL=
# DECISION_IDS_ENDPOINT=
# DECISION_DOCUMENT_ENDPOINT=
# Max limit is 1000 because of timeout
# API_PAGE_SIZE=1000

# Rate Limiting
# REQUESTS_PER_SECOND=5.0

# Retry Configuration
# MAX_RETRY_ATTEMPTS=3  # Max retries per single request
# MAX_TOTAL_RETRIES=10  # Max total retries across all Elasticsearch operations before triggering shutdown
# RETRY_BACKOFF_FACTOR=2.0
# RETRY_MIN_WAIT=1.0
# RETRY_MAX_WAIT=60.0

# Document Fetch Retry Configuration
# DOCUMENT_FETCH_MAX_RETRIES=3  # Maximum retry attempts per failed document
# DOCUMENT_FETCH_RETRY_MIN_WAIT=5.0  # Minimum wait time between retries (seconds)
# DOCUMENT_FETCH_RETRY_MAX_WAIT=300.0  # Maximum wait time between retries (seconds)
# DOCUMENT_FETCH_RETRY_BACKOFF_MULTIPLIER=3.0  # Exponential backoff multiplier
# DOCUMENT_FETCH_RETRY_STAGGER_DELAY=2.0  # Delay between initiating retries for different documents (seconds)

# Date Range Configuration
# START_DATE=2017-01-01
# Note: END_DATE is calculated as 2 months before current date but can be overridden with an option when running the pipeline

# Storage Configuration
# DATA_DIR=data
# DECISIONS_DIR=data/decisions
# CHECKPOINT_FILE=data/checkpoint.json

# Logging Configuration
# LOG_LEVEL=INFO
# LOG_DIR=data/logs
# LOG_FILE=pipeline.log
# API_LOG_FILE=api.log
# ERROR_LOG_FILE=errors.log

# Log Management
# LOG_RETENTION_DAYS=7  # Keep logs for 7 days
# LOG_ROTATION_WHEN=midnight  # When to rotate logs
# LOG_ROTATION_INTERVAL=1  # Rotate every 1 day

# Processing Configuration
# MAX_CONCURRENT_REQUESTS=10

# Concurrency Configuration
# MAX_WORKERS_INGESTION=3  # Parallel document ingestion workers
# MAX_WORKERS_ATTACHMENTS=5  # Parallel attachment download workers
# MAX_WORKERS_ATTACHMENT_PROCESSING=2  # Parallel attachment processing workers
# EMBEDDING_BATCH_SIZE=100  # Batch size for embedding generation

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSION=3072

# Elasticsearch Configuration
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_INDEX=decision_documents

# Collection Configuration (Open WebUI Compatibility)
# COLLECTION_NAME= # This is set by Open WebUI when creating a new collection
# COLLECTION_DESCRIPTION=Knowledge for storing decisions for City of Helsinki.

# API Server Settings
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=1
# API_RELOAD=False  # Set to True for development
# API_CORS_ORIGINS=["*"]

# API Authentication
# Enable/disable API authentication (set to true for production)
# API_AUTH_ENABLED=false
# 
# API key for authentication - REQUIRED if API_AUTH_ENABLED=true
# Generate a secure key with: openssl rand -hex 32
# NEVER commit actual API keys to version control!
# API_AUTH_KEY=your-secure-api-key-here
#
# HTTP header name for API key (default: X-API-Key)
# API_AUTH_KEY_HEADER=X-API-Key
#
# Security Notes:
# - Use a minimum 32-character random key
# - Store keys securely (environment variables, secret management systems)
# - Rotate keys periodically
# - Use HTTPS in production to protect keys in transit
# - Restrict API_CORS_ORIGINS to specific domains in production (not "*")

# Scheduler Configuration
# SCHEDULER_ENABLED=false
# SCHEDULER_INTERVAL_HOURS=24
# SCHEDULER_START_TIME=  # Optional, format: "HH:MM" (e.g., "02:00")
# SCHEDULER_TIMEZONE=Europe/Helsinki
# SCHEDULER_MAX_INSTANCES=1
# PIPELINE_TIMEOUT_HOURS=72
# SCHEDULER_START_DATE=  # Default start date for scheduled runs (empty = use START_DATE)
# SCHEDULER_END_DATE=  # Default end date for scheduled runs (empty = use END_DATE)
# SCHEDULER_BATCH_SIZE=100
# SCHEDULER_SKIP_EXISTING=true
# SCHEDULER_KEEP_FILES=false
# SCHEDULER_STATE_FILE=data/scheduler_state.json
# SCHEDULER_LOG_FILE=scheduler.log
